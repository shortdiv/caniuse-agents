---
import type { GetStaticPaths } from "astro";
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { loadAgents, loadCategories } from "../lib/data.js";
import type { Feature } from "../lib/types";

const [categories, agents] = await Promise.all([
  loadCategories(),
  loadAgents(),
]);

const totalFeatures = categories.reduce(
  (count, category) => count + category.features.length,
  0,
);

const featureRows = categories.flatMap((category) =>
  category.features.map((feature: Feature) => ({
    ...feature,
    category: category.title,
    categorySlug: category.category,
  })),
);
---

<Layout title="Can I Use Agents?">
  <SiteHeader
    agentCount={agents.length}
    featureCount={totalFeatures}
    features={featureRows.map((f) => ({
      id: f.id,
      title: f.title,
      description: f.description,
      category: f.category,
    }))}
  />

  <main class="page-shell">
    {/* Category index — flat row */}
    <nav class="cat-index" aria-label="Feature categories">
      <div class="cat-index-head">
        <span class="cat-index-label">Category index</span>
      </div>
      <div class="cat-index-row">
        {
          categories.map((category) => (
            <a href={`#${category.category}`} class="cat-link">
              <span class="cat-link-name">{category.title}</span>
              <span class="cat-link-count">{category.features.length}</span>
            </a>
          ))
        }
      </div>
    </nav>

    {/* Feature sections — one per category */}
    <div id="feature-index">
      {
        categories.map((category) => (
          <section
            id={category.category}
            class="feature-section"
            data-category-card
            data-category={category.title.toLowerCase()}
          >
            <div class="feature-section-header">
              <div class="feature-section-left">
                <div class="feature-section-kicker">{category.category}</div>
                <h3 class="feature-section-title">{category.title}</h3>
                <p class="feature-section-desc">{category.description}</p>
              </div>
              <span class="feature-count">
                {category.features.length} features
              </span>
            </div>

            <div class="feature-cards">
              {category.features.map((feature) => (
                <a
                  href={`/features/${feature.id}`}
                  class="feature-card"
                  data-feature-item
                  data-searchable={`${feature.title} ${feature.description} ${category.title} ${category.category}`.toLowerCase()}
                >
                  <div class="feature-card-top">
                    <span class="feature-card-title">{feature.title}</span>
                  </div>
                  <span class="feature-card-desc">{feature.description}</span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>

  </main>

  <SiteFooter />

  <script>
    const searchInput = document.querySelector("#feature-search");
    const status = document.querySelector("#search-status");
    const categoryCards = [
      ...document.querySelectorAll("[data-category-card]"),
    ];
    const allItems = [...document.querySelectorAll("[data-feature-item]")];

    const updateSearch = () => {
      const query = (
        searchInput instanceof HTMLInputElement ? searchInput.value : ""
      )
        .trim()
        .toLowerCase();

      let visibleItems = 0;

      for (const item of allItems) {
        const haystack = item.getAttribute("data-searchable") ?? "";
        const matches = query === "" || haystack.includes(query);
        item.toggleAttribute("hidden", !matches);

        if (matches) {
          visibleItems += 1;
        }
      }

      for (const card of categoryCards) {
        const matchingChildren = card.querySelectorAll(
          "[data-feature-item]:not([hidden])",
        ).length;
        card.toggleAttribute("hidden", matchingChildren === 0);
      }

      if (status) {
        status.textContent =
          query === ""
            ? `Showing all ${allItems.length} feature entries on this page.`
            : `Showing ${visibleItems} matching feature entries for "${query}".`;
      }
    };

    searchInput?.addEventListener("input", updateSearch);

    // If navigated here with ?q=, prefill and run search
    const params = new URLSearchParams(window.location.search);
    const q = params.get("q");
    if (q && searchInput instanceof HTMLInputElement) {
      searchInput.value = q;
      updateSearch();
    }
  </script>
</Layout>

<style>
  :global(body) {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
  }

  :global(a) {
    color: inherit;
  }

  .page-shell {
    width: 100%;
  }

  /* ─── Category index ─── */
  .cat-index {
    background: var(--bg-sunken, var(--surface-alt));
    width: 100%;
  }

  .cat-index-head {
    padding: 16px 24px 6px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    max-width: 1160px;
    margin: 0 auto;
  }

  .cat-index-label {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .cat-index-hint {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-subtle);
  }

  .cat-index-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    padding: 0 16px 16px;
    gap: 4px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .cat-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 14px;
    text-decoration: none;
    border-radius: 2px;
    background-color: var(--bg);
  }

  .cat-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  @media (prefers-color-scheme: dark) {
    .cat-link:hover {
      background: rgba(255, 255, 255, 0.04);
    }
  }

  .cat-link-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
  }

  .cat-link-count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-subtle);
    font-weight: 600;
  }

  /* ─── Feature sections ─── */
  .feature-section {
    background: var(--bg);
  }

  .feature-section-header {
    padding: 28px 24px 14px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 24px;
    flex-wrap: wrap;
    max-width: 1160px;
    margin: 0 auto;
  }

  .feature-section-left {
    flex: 1;
    min-width: 280px;
  }

  .feature-section-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .feature-section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.015em;
    color: var(--text);
    margin: 0 0 8px;
  }

  .feature-section-desc {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text-muted);
    max-width: 720px;
    margin: 0;
  }

  .feature-count {
    flex-shrink: 0;
    padding: 4px 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    border-radius: 2px;
    white-space: nowrap;
  }

  /* ─── Feature cards ─── */
  .feature-cards {
    padding: 4px 24px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: var(--bg-elev, var(--surface));
    border: 1px solid var(--border);
    padding: 14px 16px;
    border-radius: 2px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 90ms ease;
  }

  .feature-card:hover {
    border-color: var(--accent);
  }

  .feature-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
  }

  .feature-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--text);
    line-height: 1.3;
  }

  .feature-card-desc {
    font-family: var(--font-body);
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--text-muted);
  }

  /* ─── Footer ─── */

  [hidden] {
    display: none !important;
  }

  @media (max-width: 900px) {
    .feature-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .feature-section-header {
      padding: 20px 16px 10px;
      flex-direction: column;
    }

    .feature-cards {
      padding: 4px 16px 16px;
    }

    .cat-index-row {
      grid-template-columns: 1fr;
    }
  }
</style>
