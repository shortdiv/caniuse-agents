---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CiuTable from "../../components/CiuTable.astro";
import {
  getCurrentFeatureSupport,
  getFeatureData,
  loadAgents,
  loadCategories,
} from "../../lib/data.js";
import type { FeatureCategory, Feature, SupportRow } from "../../lib/types";
import type { Agent } from "../../lib/types";

interface Props {
  feature: Feature;
  category: FeatureCategory;
}

export async function getStaticPaths() {
  const categories = await loadCategories();

  return categories.flatMap((category) =>
    category.features.map((feature) => ({
      params: { featureId: feature.id },
      props: {
        feature,
        category,
      },
    })),
  );
}

const { feature, category } = Astro.props as Props;
const [agents, categories] = await Promise.all([
  loadAgents(),
  loadCategories(),
]);
const featureData = await getFeatureData(feature.id);
const totalFeatures = categories.reduce((n, c) => n + c.features.length, 0);

const supportRows: SupportRow[] = agents.map((agent: Agent) => ({
  agent,
  support: getCurrentFeatureSupport(agent, feature.id),
}));

const allFeatures = categories.flatMap((c) =>
  c.features.map((f) => ({
    id: f.id,
    title: f.title,
    description: f.description,
    category: c.title,
  })),
);
---

<Layout title={`${feature.title} — Can I Use Agents?`}>
  {/* ─── Persistent site header ─── */}
  <SiteHeader
    agentCount={agents.length}
    featureCount={totalFeatures}
    features={allFeatures}
  />

  <main class="page-shell">
    {/* ─── Breadcrumb ─── */}
    <div class="breadcrumb-row">
      <span class="breadcrumb">
        <a href="/">Index</a>
        <span class="breadcrumb-sep">›</span>
        <a href={`/#${category.category}`}>{category.title}</a>
      </span>
    </div>

    {/* ─── Matrix section (feature title lives inside) ─── */}
    <section class="matrix-section">
      <header class="matrix-feature-header">
        <div class="matrix-top-meta">
          <span>Agent support · {category.title}</span>
        </div>
        <h2 class="matrix-feature-title">{feature.title}</h2>
        <p class="matrix-feature-blurb">{feature.description}</p>
        <div class="matrix-pills">
          {feature.group && <span class="pill">{feature.group}</span>}
          <span class="pill">{category.title}</span>
          <span class="pill">{agents.length} agents tracked</span>
        </div>
      </header>

      <CiuTable supportRows={supportRows} featureData={featureData} />
    </section>

    {/* ─── Agent mapping & sub-capabilities ─── */}
    {
      (feature.agent_mapping || feature.sub_capabilities) && (
        <section class="details-section">
          {feature.agent_mapping && (
            <div class="details-block">
              <h3>Agent event mapping</h3>
              <ul class="mapping-list">
                {Object.entries(feature.agent_mapping).map(
                  ([agentId, eventName]) => (
                    <li>
                      <span class="mapping-agent">{agentId}</span>
                      <code class="mapping-event">{eventName}</code>
                    </li>
                  ),
                )}
              </ul>
            </div>
          )}
          {feature.sub_capabilities && feature.sub_capabilities.length > 0 && (
            <div class="details-block">
              <h3>Sub-capabilities</h3>
              <ul class="subcap-list">
                {feature.sub_capabilities.map((cap: string) => (
                  <li>{cap}</li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )
    }

    {/* ─── Related features ─── */}
    {
      feature.group && (
        <section class="related-section">
          <header class="related-header">
            <h2>Related features</h2>
            <span class="related-meta">
              {feature.group} · {category.title}
            </span>
          </header>
          <ul class="related-list">
            {category.features
              .filter((f) => f.group === feature.group && f.id !== feature.id)
              .map((f) => (
                <li>
                  <a href={`/features/${f.id}`}>
                    <div class="related-content">
                      <span class="related-title">{f.title}</span>
                      <span class="related-desc">{f.description}</span>
                    </div>
                    <span class="related-arrow">
                      View
                      <svg
                        viewBox="0 0 16 16"
                        width="12"
                        height="12"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                      >
                        <path d="M3 8h10M9 4l4 4-4 4" />
                      </svg>
                    </span>
                  </a>
                </li>
              ))}
          </ul>
        </section>
      )
    }

    {/* ─── Footer ─── */}
    <footer class="page-footer">
      <div>
        <a href="/" class="footer-link">Back to index</a>
        <span class="footer-note">
          — A reference catalog of agent capabilities. Original work,
          structurally inspired by reference compatibility tables.</span
        >
      </div>
    </footer>
  </main>
</Layout>

<style>
  :global(body) {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
  }

  :global(a) {
    color: inherit;
  }

  .page-shell {
    max-width: 1160px;
    margin: 0 auto;
    padding-top: 20px;
  }

  /* ─── Breadcrumb ─── */
  .breadcrumb-row {
    padding: 4px 0 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .breadcrumb {
    font: 500 11px/1 var(--font-sans);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .breadcrumb a {
    color: var(--text-subtle);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--text);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  /* ─── Matrix section with feature title ─── */
  .matrix-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    overflow: hidden;
  }

  .matrix-feature-header {
    padding: 26px 26px 22px;
    border-bottom: 0.5px solid var(--border);
  }

  .matrix-top-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
    font: 500 11px/1 var(--font-sans);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .matrix-feature-title {
    font: 400 clamp(1.8rem, 5vw, 2.5rem)/1.05 var(--font-serif);
    letter-spacing: -0.02em;
    margin: 0 0 10px;
    color: var(--text);
    text-wrap: balance;
    max-width: 820px;
  }

  .matrix-feature-blurb {
    font: 15px/1.55 var(--font-sans);
    color: var(--text-muted);
    margin: 0 0 14px;
    max-width: 640px;
  }

  .matrix-pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border: 0.5px solid var(--border);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
    font: 12px/1 var(--font-sans);
    padding: 5px 9px;
    border-radius: 999px;
    letter-spacing: 0.01em;
  }

  @media (prefers-color-scheme: light) {
    .pill {
      background: rgba(0, 0, 0, 0.04);
    }
  }

  /* ─── Details section ─── */
  .details-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    margin-top: 18px;
    padding: 22px 26px;
  }

  .details-block + .details-block {
    margin-top: 18px;
    padding-top: 18px;
    border-top: 0.5px solid var(--border);
  }

  .details-block h3 {
    font: 500 11px/1 var(--font-sans);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin: 0 0 10px;
  }

  .mapping-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .mapping-list li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    background: var(--surface-alt);
    border: 0.5px solid var(--border);
    border-radius: 4px;
  }

  .mapping-agent {
    font: 12px/1 var(--font-sans);
    color: var(--text-muted);
  }

  .mapping-event {
    font: 12px/1 var(--font-mono);
    color: var(--accent);
  }

  .subcap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .subcap-list li {
    font: 13px/1.5 var(--font-sans);
    color: var(--text-muted);
    padding-left: 14px;
    position: relative;
  }

  .subcap-list li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--text-subtle);
  }

  /* ─── Related ─── */
  .related-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    margin-top: 18px;
    overflow: hidden;
  }

  .related-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px 14px;
    border-bottom: 0.5px solid var(--border);
  }

  .related-header h2 {
    font: 500 17px/1 var(--font-sans);
    margin: 0;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .related-meta {
    font: 12px/1 var(--font-sans);
    color: var(--text-muted);
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related-list li + li {
    border-top: 0.5px solid var(--border);
  }

  .related-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 22px;
    text-decoration: none;
    color: var(--text);
    transition: background 90ms ease;
  }

  .related-list a:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  @media (prefers-color-scheme: light) {
    .related-list a:hover {
      background: rgba(0, 0, 0, 0.025);
    }
  }

  .related-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .related-title {
    font: 600 13.5px/1.2 var(--font-sans);
  }

  .related-desc {
    font: 13px/1.45 var(--font-sans);
    color: var(--text-muted);
  }

  .related-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-subtle);
    font: 11px/1 var(--font-sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  /* ─── Footer ─── */
  .page-footer {
    padding: 22px 0 32px;
    font: 12px/1.5 var(--font-sans);
    color: var(--text-muted);
  }

  .footer-link {
    color: var(--accent);
    text-decoration: none;
  }

  .footer-note {
    color: var(--text-subtle);
  }

  @media (max-width: 700px) {
    .page-shell {
      padding: 12px 12px 0;
    }

    .breadcrumb-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .matrix-feature-header {
      padding: 18px 16px;
    }

    .related-header {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
