---
import Layout from "../../layouts/Layout.astro";
import CiuTable from "../../components/CiuTable.astro";
import {
  getCurrentFeatureSupport,
  getFeatureData,
  loadAgents,
  loadCategories,
} from "../../lib/data.js";
import type { FeatureCategory, Feature, SupportRow } from "../../lib/types";
import type { Agent } from "../../lib/types";

interface Props {
  feature: Feature;
  category: FeatureCategory;
}

export async function getStaticPaths() {
  const categories = await loadCategories();

  return categories.flatMap((category) =>
    category.features.map((feature) => ({
      params: { featureId: feature.id },
      props: {
        feature,
        category,
      },
    })),
  );
}

const { feature, category } = Astro.props as Props;
const agents = await loadAgents();
const featureData = await getFeatureData(feature.id);

const supportRows: SupportRow[] = agents.map((agent: Agent) => ({
  agent,
  support: getCurrentFeatureSupport(agent, feature.id),
}));
---

<Layout title={`${feature.title} — Can I Use Agents?`}>
  {/* ─── Top bar ─── */}
  <header class="topbar">
    <a href="/" class="wordmark">
      <span class="wordmark-icon"></span>
      Can I Use Agents?
    </a>

    <div class="search-trigger" role="button" tabindex="0">
      <span class="search-inner">
        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="7" cy="7" r="4.5"/><path d="m10.5 10.5 3.5 3.5"/></svg>
        Search features, agents, categories…
      </span>
      <kbd>⌘K</kbd>
    </div>

    <nav class="topnav">
      <a href="/">Index</a>
      <a href="/#hooks">Categories</a>
    </nav>
  </header>

  <main class="page-shell">
    {/* ─── Hero ─── */}
    <section class="hero">
      <div class="hero-top">
        <span class="hero-brand">Can I Use Agents?</span>
        <span class="hero-category">{category.title}</span>
      </div>
      <h1>{feature.title}</h1>
      <p class="hero-blurb">{feature.description}</p>

      <div class="hero-pills">
        {feature.group && <span class="pill">{feature.group}</span>}
        <span class="pill">{category.title}</span>
        <span class="pill">{agents.length} agents tracked</span>
      </div>
    </section>

    {/* ─── Matrix ─── */}
    <section class="matrix-section">
      <header class="matrix-header">
        <div>
          <h2>Agent support</h2>
          <p class="matrix-subtitle">Version history across {agents.length} agents · hover any cell for release notes</p>
        </div>
      </header>

      <CiuTable supportRows={supportRows} featureData={featureData} />
    </section>

    {/* ─── Agent mapping & sub-capabilities ─── */}
    {(feature.agent_mapping || feature.sub_capabilities) && (
      <section class="details-section">
        {feature.agent_mapping && (
          <div class="details-block">
            <h3>Agent event mapping</h3>
            <ul class="mapping-list">
              {Object.entries(feature.agent_mapping).map(([agentId, eventName]) => (
                <li>
                  <span class="mapping-agent">{agentId}</span>
                  <code class="mapping-event">{eventName}</code>
                </li>
              ))}
            </ul>
          </div>
        )}
        {feature.sub_capabilities && feature.sub_capabilities.length > 0 && (
          <div class="details-block">
            <h3>Sub-capabilities</h3>
            <ul class="subcap-list">
              {feature.sub_capabilities.map((cap: string) => (
                <li>{cap}</li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )}

    {/* ─── Related features ─── */}
    {feature.group && (
      <section class="related-section">
        <header class="related-header">
          <h2>Related features</h2>
          <span class="related-meta">{feature.group} · {category.title}</span>
        </header>
        <ul class="related-list">
          {category.features
            .filter((f) => f.group === feature.group && f.id !== feature.id)
            .map((f) => (
              <li>
                <a href={`/features/${f.id}`}>
                  <div class="related-content">
                    <span class="related-title">{f.title}</span>
                    <span class="related-desc">{f.description}</span>
                  </div>
                  <span class="related-arrow">View
                    <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                  </span>
                </a>
              </li>
            ))}
        </ul>
      </section>
    )}

    {/* ─── Footer ─── */}
    <footer class="page-footer">
      <div>
        <a href="/" class="footer-link">Back to index</a>
        <span class="footer-note"> — A reference catalog of agent capabilities. Original work, structurally inspired by reference compatibility tables.</span>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* ─── Top bar ─── */
  .topbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 12px 28px;
    border-bottom: 0.5px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(15, 14, 12, 0.82);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
  }

  @media (prefers-color-scheme: light) {
    .topbar {
      background: rgba(247, 244, 236, 0.85);
    }
  }

  .wordmark {
    font: 600 12px/1 var(--font-sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    justify-self: start;
  }

  .wordmark-icon {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    background: linear-gradient(135deg, var(--accent), #9B8AE5);
    display: inline-block;
  }

  .search-trigger {
    appearance: none;
    border: 0.5px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text-muted);
    font: 13px/1 var(--font-sans);
    padding: 9px 12px 9px 14px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    cursor: text;
    width: min(440px, 44vw);
    justify-content: space-between;
  }

  @media (prefers-color-scheme: light) {
    .search-trigger {
      background: rgba(0, 0, 0, 0.025);
    }
  }

  .search-trigger:hover {
    border-color: var(--border-strong);
  }

  .search-inner {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .search-trigger kbd {
    font: 10px var(--font-mono);
    border: 0.5px solid currentColor;
    border-radius: 3px;
    padding: 1px 4px;
    opacity: 0.6;
  }

  .topnav {
    display: flex;
    gap: 22px;
    justify-self: end;
    align-items: center;
  }

  .topnav a {
    font: 13px/1 var(--font-sans);
    color: var(--text-muted);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 90ms ease;
  }

  .topnav a:hover {
    color: var(--text);
  }

  /* ─── Page shell ─── */
  .page-shell {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 28px 0;
  }

  /* ─── Hero ─── */
  .hero {
    background: var(--header-bg);
    color: var(--header-text);
    padding: 42px 36px 38px;
    border-radius: 2px;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    font: 500 11px/1 var(--font-sans);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--header-muted);
  }

  .hero-category {
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 13px;
    font-weight: 400;
  }

  .hero h1 {
    font: 400 clamp(2.4rem, 6vw, 4rem)/1.05 var(--font-serif);
    letter-spacing: -0.02em;
    margin: 14px 0 10px;
    text-wrap: balance;
    max-width: 900px;
    color: var(--header-text);
  }

  .hero-blurb {
    font: 16px/1.55 var(--font-sans);
    color: rgba(237, 231, 218, 0.82);
    margin: 0;
    max-width: 640px;
  }

  @media (prefers-color-scheme: light) {
    .hero-blurb {
      color: rgba(27, 24, 18, 0.78);
    }
  }

  .hero-pills {
    display: flex;
    gap: 8px;
    margin-top: 22px;
    flex-wrap: wrap;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    border: 0.5px solid var(--border);
    background: rgba(255, 255, 255, 0.05);
    color: var(--header-muted);
    font: 12px/1 var(--font-sans);
    padding: 5px 9px;
    border-radius: 999px;
    letter-spacing: 0.01em;
  }

  @media (prefers-color-scheme: light) {
    .pill {
      background: rgba(255, 255, 255, 0.5);
    }
  }

  /* ─── Matrix section ─── */
  .matrix-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    margin-top: 18px;
    overflow: hidden;
  }

  .matrix-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px 14px;
    border-bottom: 0.5px solid var(--border);
  }

  .matrix-header h2 {
    font: 500 17px/1 var(--font-sans);
    margin: 0;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .matrix-subtitle {
    font: 12px/1.4 var(--font-sans);
    color: var(--text-subtle);
    margin: 6px 0 0;
  }

  /* ─── Details (agent mapping + sub-capabilities) ─── */
  .details-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    margin-top: 18px;
    overflow: hidden;
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .details-block h3 {
    font: 500 13px/1 var(--font-sans);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 10px;
  }

  .mapping-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .mapping-list li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0.5px solid var(--border);
    border-radius: 6px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, 0.03);
  }

  @media (prefers-color-scheme: light) {
    .mapping-list li {
      background: rgba(0, 0, 0, 0.02);
    }
  }

  .mapping-agent {
    font: 12px/1 var(--font-sans);
    color: var(--text-muted);
  }

  .mapping-event {
    font: 12px/1 var(--font-mono);
    color: var(--accent);
  }

  .subcap-list {
    margin: 0;
    padding: 0 0 0 18px;
  }

  .subcap-list li {
    font: 13px/1.55 var(--font-sans);
    color: var(--text-muted);
    padding: 2px 0;
  }

  /* ─── Related ─── */
  .related-section {
    border: 0.5px solid var(--border);
    background: var(--surface);
    border-radius: 2px;
    margin-top: 18px;
    overflow: hidden;
  }

  .related-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px 14px;
    border-bottom: 0.5px solid var(--border);
  }

  .related-header h2 {
    font: 500 17px/1 var(--font-sans);
    margin: 0;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .related-meta {
    font: 12px/1 var(--font-sans);
    color: var(--text-muted);
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related-list li + li {
    border-top: 0.5px solid var(--border);
  }

  .related-list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 22px;
    text-decoration: none;
    color: var(--text);
    transition: background 90ms ease;
  }

  .related-list a:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  @media (prefers-color-scheme: light) {
    .related-list a:hover {
      background: rgba(0, 0, 0, 0.025);
    }
  }

  .related-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .related-title {
    font: 600 13.5px/1.2 var(--font-sans);
  }

  .related-desc {
    font: 13px/1.45 var(--font-sans);
    color: var(--text-muted);
  }

  .related-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-subtle);
    font: 11px/1 var(--font-sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    flex-shrink: 0;
  }

  /* ─── Footer ─── */
  .page-footer {
    padding: 22px 0 32px;
    font: 12px/1.5 var(--font-sans);
    color: var(--text-muted);
    display: flex;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer-link {
    color: var(--accent);
    text-decoration: none;
  }

  .footer-note {
    color: var(--text-subtle);
  }

  /* ─── Responsive ─── */
  @media (max-width: 700px) {
    .topbar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      padding: 10px 14px;
    }

    .search-trigger {
      width: 100%;
      order: 3;
    }

    .topnav {
      gap: 14px;
    }

    .page-shell {
      padding: 16px 12px 0;
    }

    .hero {
      padding: 24px 18px;
    }

    .matrix-header,
    .related-header {
      flex-direction: column;
      gap: 6px;
    }

    .related-list a {
      padding: 12px 14px;
    }
  }
</style>
