---
interface Props {
  agentCount: number;
  featureCount: number;
  features?: { id: string; title: string; description: string; category: string }[];
}

const { agentCount, featureCount, features = [] } = Astro.props;
---

<section class="site-header">
  <div class="site-header-top">
    <a href="/" class="site-wordmark">Can I Use Agents?</a>
    <span class="site-meta"
      >{agentCount} agents · {featureCount} tracked features</span
    >
  </div>

  <h1 class="site-title">Agent capability tables</h1>
  <p class="site-blurb">
    Search across tools, MCP, memory, instructions, hooks, and other agent
    features.
  </p>

  <div class="site-search-wrap">
    <div class="site-search-label">
      Search feature name, category, or description
    </div>
    <div class="site-search-row">
      <div class="site-search-field">
        <svg
          viewBox="0 0 16 16"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          ><circle cx="7" cy="7" r="4.5"></circle><path d="m10.5 10.5 3.5 3.5"
          ></path></svg
        >
        <input
          id="feature-search"
          type="search"
          placeholder="Search: MCP, subagents, shell, AGENTS.md…"
          autocomplete="off"
        />
      </div>
      <a href="/#feature-index" class="site-browse-btn">Browse index</a>
    </div>
    <p class="site-search-hint" id="search-status"></p>
  </div>

  {/* Live search dropdown */}
  <div class="search-results" id="search-results" hidden></div>
</section>

{/* Embed feature index for client-side search */}
<script id="feature-index-data" type="application/json" set:html={JSON.stringify(features)} />

<script>
  const input = document.querySelector("#feature-search") as HTMLInputElement;
  const results = document.querySelector("#search-results") as HTMLElement;
  const status = document.querySelector("#search-status") as HTMLElement;
  const dataEl = document.querySelector("#feature-index-data");

  if (input && results && dataEl) {
    const features: { id: string; title: string; description: string; category: string }[] =
      JSON.parse(dataEl.textContent || "[]");

    let activeIdx = -1;

    const render = (items: typeof features) => {
      if (items.length === 0) {
        results.innerHTML = `<div class="search-empty">No matching features.</div>`;
        return;
      }
      results.innerHTML = items
        .map(
          (f, i) =>
            `<a href="/features/${f.id}" class="search-result${i === activeIdx ? " active" : ""}" data-idx="${i}">
              <span class="search-result-title">${f.title}</span>
              <span class="search-result-cat">${f.category}</span>
              <span class="search-result-desc">${f.description}</span>
            </a>`,
        )
        .join("");
    };

    const update = () => {
      const q = input.value.trim().toLowerCase();
      if (!q) {
        results.hidden = true;
        if (status) status.textContent = "";
        activeIdx = -1;
        return;
      }

      const matched = features.filter(
        (f) =>
          f.title.toLowerCase().includes(q) ||
          f.description.toLowerCase().includes(q) ||
          f.category.toLowerCase().includes(q),
      ).slice(0, 10);

      activeIdx = matched.length > 0 ? 0 : -1;
      render(matched);
      results.hidden = false;

      if (status) {
        status.textContent = `${matched.length} result${matched.length === 1 ? "" : "s"}`;
      }
    };

    input.addEventListener("input", update);

    input.addEventListener("keydown", (e) => {
      if (results.hidden) return;

      const links = results.querySelectorAll(".search-result");

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = Math.min(activeIdx + 1, links.length - 1);
        links.forEach((el, i) => el.classList.toggle("active", i === activeIdx));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, 0);
        links.forEach((el, i) => el.classList.toggle("active", i === activeIdx));
      } else if (e.key === "Enter") {
        e.preventDefault();
        const active = results.querySelector(".search-result.active") as HTMLAnchorElement;
        if (active) {
          window.location.href = active.href;
        }
      } else if (e.key === "Escape") {
        results.hidden = true;
        input.blur();
      }
    });

    // Close dropdown when clicking outside
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".site-search-wrap")) {
        results.hidden = true;
      }
    });

    // Re-open on focus if there's a query
    input.addEventListener("focus", () => {
      if (input.value.trim()) update();
    });
  }
</script>

<style>
  .site-header {
    background: var(--header-bg);
    color: var(--header-text);
    padding: 26px 32px 28px;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    max-width: 1160px;
    margin: 0 auto;
  }

  .site-header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .site-wordmark {
    font: 700 11px/1 var(--font-sans);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--header-muted);
    text-decoration: none;
  }

  .site-wordmark:hover {
    color: var(--header-text);
  }

  .site-meta {
    font: 500 12.5px/1 var(--font-sans);
    letter-spacing: 0.02em;
    color: var(--header-muted);
  }

  .site-title {
    font: 400 clamp(2.2rem, 6vw, 3.5rem)/1.05 var(--font-serif);
    letter-spacing: -0.02em;
    margin: 14px 0 8px;
    text-wrap: balance;
    color: var(--header-text);
  }

  .site-blurb {
    font: 15.5px/1.5 var(--font-sans);
    color: rgba(237, 231, 218, 0.82);
    margin: 0;
    max-width: 680px;
  }

  @media (prefers-color-scheme: light) {
    .site-blurb {
      color: rgba(27, 24, 18, 0.78);
    }
  }

  .site-search-wrap {
    margin-top: 20px;
    background: rgba(0, 0, 0, 0.18);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 12px 14px;
  }

  @media (prefers-color-scheme: light) {
    .site-search-wrap {
      background: rgba(255, 255, 255, 0.55);
      border-color: rgba(0, 0, 0, 0.1);
    }
  }

  .site-search-label {
    font: 600 10.5px/1 var(--font-sans);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--header-muted);
    margin-bottom: 9px;
  }

  .site-search-row {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }

  .site-search-field {
    flex: 1;
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.35);
    color: rgba(237, 231, 218, 0.82);
    font: 14px/1 var(--font-sans);
    padding: 10px 14px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .site-search-field input {
    flex: 1;
    appearance: none;
    border: none;
    outline: none;
    background: transparent;
    color: inherit;
    font: inherit;
    padding: 0;
    min-width: 0;
  }

  .site-search-field input::placeholder {
    color: rgba(237, 231, 218, 0.5);
  }

  .site-search-hint {
    font: 13px/1 var(--font-sans);
    color: var(--header-muted);
    margin: 8px 0 0;
  }

  .site-search-hint:empty {
    display: none;
  }

  @media (prefers-color-scheme: light) {
    .site-search-field {
      background: rgba(255, 255, 255, 0.85);
      border-color: rgba(0, 0, 0, 0.1);
      color: rgba(27, 24, 18, 0.78);
    }

    .site-search-field input::placeholder {
      color: rgba(27, 24, 18, 0.4);
    }

    .site-search-hint {
      color: rgba(27, 24, 18, 0.55);
    }
  }

  /* ─── Search results dropdown ─── */
  .search-results {
    margin-top: 6px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    max-height: 400px;
    overflow-y: auto;
  }

  .site-browse-btn {
    appearance: none;
    border: none;
    background: var(--accent);
    color: #1b1812;
    font: 600 13px/1 var(--font-sans);
    padding: 0 18px;
    border-radius: 6px;
    cursor: default;
    letter-spacing: 0.01em;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .site-browse-btn:hover {
    background: var(--accent-hover);
  }

  :global(.search-result) {
    display: block;
    padding: 10px 16px;
    text-decoration: none;
    color: var(--text);
    border-top: 0.5px solid var(--border);
    transition: background 60ms ease;
  }

  :global(.search-result:first-child) {
    border-top: none;
  }

  :global(.search-result:hover),
  :global(.search-result.active) {
    background: rgba(255, 255, 255, 0.05);
  }

  @media (prefers-color-scheme: light) {
    :global(.search-result:hover),
    :global(.search-result.active) {
      background: rgba(0, 0, 0, 0.04);
    }
  }

  :global(.search-result-title) {
    display: block;
    font: 600 13.5px/1.2 var(--font-sans);
  }

  :global(.search-result-cat) {
    display: inline-block;
    font: 11px/1 var(--font-sans);
    color: var(--text-subtle);
    margin-top: 2px;
  }

  :global(.search-result-desc) {
    display: block;
    font: 12.5px/1.4 var(--font-sans);
    color: var(--text-muted);
    margin-top: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-empty) {
    padding: 24px 16px;
    text-align: center;
    color: var(--text-subtle);
    font: 13px var(--font-sans);
  }

  @media (max-width: 700px) {
    .site-header {
      padding: 18px 14px 20px;
    }

    .site-header-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .site-search-row {
      flex-direction: column;
    }

    .site-browse-btn {
      padding: 10px 18px;
      justify-content: center;
    }
  }
</style>
