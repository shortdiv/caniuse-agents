---
interface Props {
  agentCount: number;
  featureCount: number;
  features?: {
    id: string;
    title: string;
    description: string;
    category: string;
  }[];
}

const { agentCount, featureCount, features = [] } = Astro.props;
---

<section class="site-header">
  {/* Top bar — wordmark + nav */}
  <div class="site-header-nav">
    <a href="/" class="site-wordmark">
      <span class="wm-name">caniuse</span><span class="wm-dot">·</span><span
        class="wm-agents">agents</span
      >
    </a>
    <div class="site-nav-right">
      <a
        href="https://github.com/nicedoc/caniuse-agents"
        class="nav-link"
        target="_blank"
        rel="noopener">contribute</a
      >
    </div>
  </div>

  {/* Hero — title + subtitle + search */}
  <div class="site-hero">
    <div class="site-hero-inner">
      <div class="site-hero-top">
        <span class="site-kicker">Reference / Capabilities</span>
      </div>

      <h1 class="site-title">What can your agent actually do?</h1>
      <p class="site-blurb">
        A reference manual for the moving target of coding-agent capabilities.
        Updated continuously.
      </p>

      <div class="site-search-wrap">
        <label class="site-search-field">
          <span class="search-prompt">›</span>
          <input
            id="feature-search"
            type="search"
            placeholder="Search feature, category, or agent…"
            autocomplete="off"
          />
          <kbd class="search-kbd">⌘K</kbd>
        </label>
        <button type="button" class="site-search-btn" id="search-submit"
          >Search</button
        >
        <div class="search-results" id="search-results" hidden></div>
      </div>

      <p class="site-search-hint" id="search-status"></p>
    </div>
  </div>
</section>
<div class="search-overlay" id="search-overlay" hidden></div>

{/* Embed feature index for client-side search */}
<script
  id="feature-index-data"
  type="application/json"
  set:html={JSON.stringify(features)}
/>

<script>
  const input = document.querySelector("#feature-search") as HTMLInputElement;
  const results = document.querySelector("#search-results") as HTMLElement;
  const overlay = document.querySelector("#search-overlay") as HTMLElement;
  const status = document.querySelector("#search-status") as HTMLElement;
  const dataEl = document.querySelector("#feature-index-data");

  function showDropdown() {
    results.hidden = false;
    if (overlay) overlay.hidden = false;
  }

  function hideDropdown() {
    results.hidden = true;
    if (overlay) overlay.hidden = true;
  }
  const searchBtn = document.querySelector("#search-submit");

  // Search button focuses input or navigates to first result
  if (searchBtn && input) {
    searchBtn.addEventListener("click", () => {
      if (input.value.trim()) {
        const firstResult = document.querySelector(
          ".search-result",
        ) as HTMLAnchorElement;
        if (firstResult) {
          window.location.href = firstResult.href;
        }
      } else {
        input.focus();
      }
    });
  }

  // Popular chips — fill search and trigger
  document.querySelectorAll("[data-search-chip]").forEach((chip) => {
    chip.addEventListener("click", () => {
      if (input) {
        input.value = (chip as HTMLElement).dataset.searchChip || "";
        input.focus();
        input.dispatchEvent(new Event("input"));
      }
    });
  });

  if (input && results && dataEl) {
    const features: {
      id: string;
      title: string;
      description: string;
      category: string;
    }[] = JSON.parse(dataEl.textContent || "[]");

    let activeIdx = -1;

    const render = (items: typeof features) => {
      if (items.length === 0) {
        results.innerHTML = `<div class="search-empty">No matching features.</div>`;
        return;
      }
      results.innerHTML = items
        .map(
          (f, i) =>
            `<a href="/features/${f.id}" class="search-result${i === activeIdx ? " active" : ""}" data-idx="${i}">
              <span class="search-result-title">${f.title}</span>
              <span class="search-result-cat">${f.category}</span>
              <span class="search-result-desc">${f.description}</span>
            </a>`,
        )
        .join("");
    };

    const update = () => {
      const q = input.value.trim().toLowerCase();
      if (!q) {
        hideDropdown();
        if (status) status.textContent = "";
        activeIdx = -1;
        return;
      }

      const matched = features
        .filter(
          (f) =>
            f.title.toLowerCase().includes(q) ||
            f.description.toLowerCase().includes(q) ||
            f.category.toLowerCase().includes(q),
        )
        .slice(0, 10);

      activeIdx = matched.length > 0 ? 0 : -1;
      render(matched);
      showDropdown();

      if (status) {
        status.textContent = `${matched.length} result${matched.length === 1 ? "" : "s"}`;
      }
    };

    input.addEventListener("input", update);

    input.addEventListener("keydown", (e) => {
      if (results.hidden) return;

      const links = results.querySelectorAll(".search-result");

      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = Math.min(activeIdx + 1, links.length - 1);
        links.forEach((el, i) =>
          el.classList.toggle("active", i === activeIdx),
        );
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, 0);
        links.forEach((el, i) =>
          el.classList.toggle("active", i === activeIdx),
        );
      } else if (e.key === "Enter") {
        e.preventDefault();
        const active = results.querySelector(
          ".search-result.active",
        ) as HTMLAnchorElement;
        if (active) {
          window.location.href = active.href;
        }
      } else if (e.key === "Escape") {
        hideDropdown();
        input.blur();
      }
    });

    // Close dropdown when clicking outside
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".site-search-wrap")) {
        hideDropdown();
      }
    });

    // Re-open on focus if there's a query
    input.addEventListener("focus", () => {
      if (input.value.trim()) update();
    });
  }
</script>

<style>
  .site-header {
    background: var(--bg-elev, var(--surface));
    color: var(--text);
    width: 100%;
  }

  /* ─── Nav bar ─── */
  .site-header-nav {
    padding: 14px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-wordmark {
    font-family: var(--font-display);
    font-size: 17px;
    text-decoration: none;
    display: flex;
    align-items: baseline;
    gap: 0;
  }

  .wm-name {
    font-weight: 700;
    color: var(--text);
  }
  .wm-dot {
    color: var(--accent);
    margin: 0 2px;
  }
  .wm-agents {
    font-weight: 400;
    color: var(--accent);
  }

  .site-nav-right {
    display: flex;
    gap: 18px;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-subtle);
    letter-spacing: 0.02em;
  }

  .nav-link {
    color: var(--text-muted);
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--text);
  }
  .nav-sep {
    color: var(--border);
  }
  .nav-version {
    color: var(--text-subtle);
  }

  /* ─── Hero ─── */
  .site-hero {
    border-bottom: 1px solid var(--border);
  }

  .site-hero-inner {
    padding: 40px 24px 32px;
    max-width: 1160px;
    margin: 0 auto;
  }

  .site-hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 18px;
  }

  .site-kicker {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .site-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-subtle);
  }

  .site-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 12px;
  }

  .site-blurb {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    color: var(--text-muted);
    max-width: 680px;
    margin: 0 0 28px;
  }

  /* ─── Search ─── */
  .site-search-wrap {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px;
    align-items: stretch;
    position: relative;
    z-index: 20;
  }

  .site-search-field {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1.5px solid var(--border-strong);
    background: var(--bg);
    padding: 0 14px;
    height: 42.69px;
    cursor: text;
  }

  .search-prompt {
    color: var(--text-subtle);
    font-family: var(--font-mono);
  }

  .site-search-field input {
    flex: 1;
    appearance: none;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-mono);
    font-size: 15px;
    color: var(--text);
    padding: 0;
    min-width: 0;
  }

  .site-search-field input::placeholder {
    color: var(--text-subtle);
  }

  .search-kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-subtle);
    border: 1px solid var(--border);
    padding: 2px 5px;
    border-radius: 2px;
  }

  .site-search-btn {
    background: var(--accent);
    color: var(--accent-ink, #fff);
    border: 1.5px solid var(--border-strong);
    border-left: 1.5px solid var(--border-strong);
    padding: 0 22px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.005em;
    cursor: pointer;
    white-space: nowrap;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .site-search-btn:hover {
    background: var(--accent-hover);
  }

  /* ─── Chips ─── */
  .site-chips {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    align-items: center;
  }

  .chip-label {
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 10px;
    margin-right: 4px;
  }

  .chip {
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 2px;
    color: var(--text-muted);
    background: var(--bg);
    cursor: pointer;
  }

  .chip:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .site-search-hint {
    font: 12px/1 var(--font-mono);
    color: var(--text-subtle);
    margin: 10px 0 0;
  }

  .site-search-hint:empty {
    display: none;
  }

  /* ─── Search results dropdown ─── */
  :global(.search-overlay) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 15;
    pointer-events: auto;
  }

  @media (prefers-color-scheme: light) {
    :global(.search-overlay) {
      background: rgba(0, 0, 0, 0.15);
    }
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    max-height: 400px;
    overflow-y: auto;
    z-index: 20;
    grid-column: 1 / -1;
  }

  :global(.search-result) {
    display: block;
    padding: 10px 16px;
    text-decoration: none;
    color: var(--text);
    border-top: 1px solid var(--border);
    transition: background 60ms ease;
  }

  :global(.search-result:first-child) {
    border-top: none;
  }

  :global(.search-result:hover),
  :global(.search-result.active) {
    background: rgba(255, 255, 255, 0.05);
  }

  @media (prefers-color-scheme: light) {
    :global(.search-result:hover),
    :global(.search-result.active) {
      background: rgba(0, 0, 0, 0.04);
    }
  }

  :global(.search-result-title) {
    display: block;
    font: 600 13.5px/1.2 var(--font-display);
  }

  :global(.search-result-cat) {
    display: inline-block;
    font: 11px/1 var(--font-mono);
    color: var(--text-subtle);
    margin-top: 2px;
  }

  :global(.search-result-desc) {
    display: block;
    font: 12.5px/1.4 var(--font-body);
    color: var(--text-muted);
    margin-top: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.search-empty) {
    padding: 24px 16px;
    text-align: center;
    color: var(--text-subtle);
    font: 13px var(--font-body);
  }

  @media (max-width: 700px) {
    .site-header-nav {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }

    .site-hero {
      padding: 24px 16px;
    }

    .site-search-wrap {
      grid-template-columns: 1fr;
    }

    .site-search-btn {
      padding: 12px 22px;
      justify-content: center;
    }

    .site-nav-right {
      gap: 12px;
    }
  }
</style>
