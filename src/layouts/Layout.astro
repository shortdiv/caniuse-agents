---
import "../styles/global.css";

interface Props {
    title?: string;
}

const { title = "Can I Use Agents?" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content="Compatibility tables for AI coding agent features. Compare hooks, MCP, tools, instructions, and memory support across Claude Code, Cline CLI, Codex CLI, GitHub Copilot CLI, and Cursor." />
        <meta property="og:title" content={title} />
        <meta property="og:description" content="Compatibility tables for AI coding agent features. Compare support across Claude Code, Cline CLI, Codex CLI, GitHub Copilot CLI, and Cursor." />
        <meta property="og:image" content="https://caniuseagents.com/favicon.svg" />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content="Compatibility tables for AI coding agent features." />
        <meta name="twitter:image" content="https://caniuseagents.com/favicon.svg" />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
